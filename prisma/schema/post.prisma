model Post {
  id         String     @id @default(uuid())
  title      String     @db.VarChar(255)
  comment    String     @db.Text
  thumbnail  String?
  isFeatured Boolean
  status     PostStatus @default(PUBLISHED)
  tags       String[]
  views      Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  authroId String
  authro   User   @relation(fields: [authroId], references: [id], onDelete: Cascade)

  comments Comment[]

  @@index([authroId])
  @@map("posts")
}
